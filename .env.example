# Database (required for API server)
# Supabase: use the "Session pooler" or "Direct" URI (port 5432) for local dev,
# OR the "Transaction pooler" URI (port 6543) — the app auto-configures for both.
# Get these from Supabase → Project Settings → Database → Connect
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# Demo mode — skips Stripe and uses fake checkout (recommended for local demo)
DEMO_MODE=true

# API server
PORT=8080
ADMIN_PASSWORD=walkercreek2024
SESSION_SECRET=change-me-in-production

# Frontend dev server (required by vite.config.ts)
# PORT=24478
# BASE_PATH=/

# Optional: public site URL for checkout redirects
# SITE_URL=http://localhost:24478

# Stripe (only needed when DEMO_MODE is not set)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email (optional — skipped when not configured)
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# SMTP_PORT=587

# Netlify: set API_PROXY_URL to your deployed API origin (no trailing slash)
# API_PROXY_URL=https://your-api.example.com
